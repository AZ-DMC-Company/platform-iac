{
  "dashboard": {
    "id": null,
    "uid": "academic-backend",
    "title": "Backend Java Spring - Academic Dashboard",
    "tags": ["academic", "backend", "prometheus"],
    "timezone": "browser",
    "schemaVersion": 36,
    "version": 1,
    "refresh": "10s",
    "panels": [
      {
        "type": "gauge",
        "title": "System CPU Usage",
        "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
        "id": 1,
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "system_cpu_usage",
            "interval": "",
            "legendFormat": "CPU Usage",
            "refId": "A"
          }
        ],
        "maxValue": 1,
        "minValue": 0,
        "unit": "percent"
      },
      {
        "type": "graph",
        "title": "Executor Active Threads",
        "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
        "id": 2,
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "executor_active_threads",
            "legendFormat": "{{name}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          { "format": "short", "min": 0 },
          { "format": "short", "min": null }
        ]
      },
      {
        "type": "graph",
        "title": "JVM GC Memory Promoted",
        "gridPos": { "x": 0, "y": 8, "w": 24, "h": 8 },
        "id": 3,
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "jvm_gc_memory_promoted_bytes_total",
            "legendFormat": "GC Promoted",
            "refId": "A"
          }
        ],
        "yaxes": [
          { "format": "bytes", "min": 0 },
          { "format": "short", "min": null }
        ]
      }
    ]
  },
  "overwrite": true
}